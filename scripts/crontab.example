# Example crontab for the smart meter data pipeline (smgw2influx.sh,
# daily-tar.sh, monthly-assemble.sh). Copy the lines you need into
# `crontab -e`, then fill in the placeholders (<...>) for your setup.
#
# Secrets (gateway password, InfluxDB token) are intentionally kept out of
# this file. Put them in a separate env file that is NOT committed to git
# (chmod 600), e.g. ~/.config/smgw2influx.env:
#
#   export SMGW_PASSWORD='...'
#   export INFLUXDB_TOKEN='...'
#
# cron does not source your shell profile, so each job below sources that
# file itself before running the script.

# Every 14 minutes: pull the latest readings from the gateway and write them
# to InfluxDB. 14 minutes (not 15) is intentional: it overlaps the meter's
# own 15-minute reading interval so that a single missed run can't create a
# gap in the data.
*/14 * * * * . ~/.config/smgw2influx.env && /path/to/smart-meter-toolkit/scripts/smgw2influx.sh \
  --user <gateway-user> --meter <meter-logical-name> \
  --influx-url http://<influxdb-host>:8086 --influx-org <org> --influx-bucket <bucket> \
  --measurement <measurement-name> \
  > /dev/null 2>&1

# Nightly at 01:50 (before daily-tar.sh below): merge newer/backfilled
# readings from the data directory into the smart-meter Excel workbook
# (meter_reading2consumption.py --append-to). The filename is resolved at
# runtime since the script renames the workbook's _to_<date> suffix after
# every successful merge. Scheduling this before daily-tar.sh isn't
# actually load-bearing - daily-tar.sh only copies files into
# archives/daily, it never deletes originals from the data directory.
# --add-gaps rescans every month sheet from scratch each run (not just the
# ones this run touched) and rewrites the "Lücken" block, so a gap in an
# older month gets removed if a later backfill closes it - e.g. finding a
# missing May reading in July.
50 1 * * * XLSX=$(ls -t /path/to/workbook-directory/<workbook-name-prefix>_from_*.xlsx | head -1) && /path/to/python3 /path/to/smart-meter-toolkit/scripts/meter_reading2consumption.py \
  --append-to "$XLSX" --folder /path/to/data-directory --divisor 10000 --add-gaps \
  >> /path/to/logs/append-excel.log 2>&1

# Daily at 00:05: check whether append-excel.log is due for rotation, per
# logrotate-append-excel.conf.example (weekly, 8 rotations kept, gzip
# compressed - copy that file, fill in its placeholder, and point this job
# at your copy). Running logrotate daily and letting it decide via its own
# state file (not root's /var/lib/logrotate/status) is the standard way to
# get reliable weekly rotation without root access.
05 0 * * * /usr/sbin/logrotate --state /path/to/logs/logrotate-state /path/to/logrotate-append-excel.conf

# Daily at 02:10: tar up yesterday's raw gateway export files.
10 2 * * * /path/to/smart-meter-toolkit/scripts/daily-tar.sh \
  --base-dir /path/to/data-directory \
  > /path/to/logs/daily-tar.log 2>&1

# Monthly on day 2 at 03:00: assemble last month's daily tars into one
# compressed monthly archive (run on day 2 so the last day of the previous
# month has definitely been archived by the job above).
0 3 2 * * /path/to/smart-meter-toolkit/scripts/monthly-assemble.sh \
  --daily-dir /path/to/data-directory/archives/daily \
  --monthly-dir /path/to/data-directory/archives/monthly \
  > /path/to/logs/monthly-assemble.log 2>&1
