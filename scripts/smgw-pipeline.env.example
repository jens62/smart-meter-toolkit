# Shared config for the smart-meter-toolkit cron pipeline
# (smgw2influx.sh, gap_backfill.py, meter_reading2consumption.py).
#
# Copy this file to e.g. ~/.config/smgw-pipeline.env, fill in the values,
# then: chmod 600 ~/.config/smgw-pipeline.env
#
# Every cron job in crontab.example sources this one file - cron doesn't
# source your shell profile, so each job does it explicitly
# (". ~/.config/smgw-pipeline.env && ...").
#
# Consolidated into one file so a change (e.g. the gateway's IP, or a new
# meter after a swap) only needs to happen in one place instead of in
# every cron line that needs it.

# --- Gateway connection ---
export SMGW_HOST='192.168.1.200'
export SMGW_USER='...'
export SMGW_PASSWORD='...'
export SMGW_METER='01005e318002.1emh0011802881.sm'

# --- InfluxDB (smgw2influx.sh, and gap_backfill.py if you want gaps it
# recovers to also land in InfluxDB, not just the Excel workbook) ---
export INFLUXDB_TOKEN='...'
export INFLUXDB_URL='http://192.168.0.194:8086'
export INFLUXDB_ORG='...'
export INFLUXDB_BUCKET='...'
# Same measurement/item name smgw2influx.sh writes to - gap_backfill.py's
# recovered points should land in the same series, not a separate one.
export INFLUXDB_MEASUREMENT='...'

# --- Filesystem layout (shared across jobs) ---
# Base directory containing data/ (raw exports) and archives/ (daily-tar.sh,
# monthly-assemble.sh output). Matches --base-dir/--folder/--out-path/
# --data-dir across the various scripts, which don't all use the same flag
# name for it.
export SMGW_BASE_DIR='/path/to/data-directory'
# Directory the Excel workbook(s) live in - meter_reading2consumption.py
# renames the workbook's _to_<date> suffix after every merge, so the
# filename itself isn't stable; jobs resolve it at runtime via
# `ls -t "$SMGW_WORKBOOK_DIR"/"$SMGW_WORKBOOK_PREFIX"_from_*.xlsx | head -1`.
export SMGW_WORKBOOK_DIR='/path/to/workbook-directory'
export SMGW_WORKBOOK_PREFIX='<workbook-name-prefix>'
export SMGW_LOG_DIR='/path/to/logs'
